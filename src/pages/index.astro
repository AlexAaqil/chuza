---
import { AppConfig } from '../data/app.config';
import { ShoesConfig } from '../data/shoes.config';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const newArrivals = ShoesConfig.shoes.filter(shoe => shoe.is_active && shoe.is_featured).sort((a, b)=>b.date_of_purchase.localeCompare(a.date_of_purchase)).slice(0,4);

// A - Z Ascending: .sort((a, b) => a.name.localeCompare(b.name))
// Z - A Descending: .sort((a, b) => b.name.localeCompare(a.name))
const mostPopular = ShoesConfig.shoes.filter(shoe => shoe.is_active && shoe.is_featured).sort((a, b) => a.name.localeCompare(b.name)).slice(0,12);
---

<Layout>
	<main class="HomePage">
		<section class="Hero">
			<div class="container-fluid">
				<div class="content">
					<h1 class="title">Walk with confidence <br> Step in Style</h1>
					<div class="actions">
						<a href="/shop">Start Shopping</a>
					</div>
				</div>

				<div class="image">
					<img src={ AppConfig.images.heroImage.src } alt="Air Force shoe hero image">
				</div>
			</div>
		</section>

		<section class="Brands">
			<div class="container-fluid">
				<div class="brands-wrapper">
					<div class="brand">
						<img src={ AppConfig.images.nikeLogo.src } alt="Nike logo">
					</div>

					<div class="brand">
						<img src={ AppConfig.images.vansLogo.src } alt="Vans logo">
					</div>

					<div class="brand">
						<img src={ AppConfig.images.newbalanceLogo.src } alt="New Balance logo">
					</div>

					<div class="brand">
						<img src={ AppConfig.images.airjordanLogo.src } alt="Air Jordan logo">
					</div>

					<div class="brand">
						<img src={ AppConfig.images.converseLogo.src } alt="Converse logo">
					</div>

					<div class="brand w-50 h-50">
						<img src={ AppConfig.images.alexanderMcqueenLogo.src } alt="Alexander Mcqueen logo">
					</div>

					<div class="brand w-50 h-50">
						<img src={ AppConfig.images.adidasLogo.src } alt="Adidas logo">
					</div>
				</div>
			</div>
		</section>

		<section class="NewArrivals">
			<div class="container-fluid">
				<div class="section-header">
					<h2>New Arrivals</h2>
				</div>

				<div class="content">
					{newArrivals.map((shoe) => (
						<div class="shoe-card">
							<div class="image">
								<img src={ shoe.image.src } alt="Shoe">
							</div>

							<div class="details">
								<p class="name">{shoe.name}</p>
								<p class="price">{new Intl.NumberFormat('en-KE', { style: 'currency', currency: 'KES', maximumFractionDigits: 0 }).format(shoe.price)}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="MostPopular">
			<div class="container-fluid">
				<div class="section-header">
					<h2>Most Popular</h2>
				</div>

				<div class="content">
					{mostPopular.map((shoe) => (
						<div class="shoe-card">
							<div class="image">
								<img src={ shoe.image.src } alt="Shoe">
							</div>

							<div class="details">
								<p class="name">{shoe.name}</p>
								<p class="price">{new Intl.NumberFormat('en-KE', { style: 'currency', currency: 'KES', maximumFractionDigits: 0 }).format(shoe.price)}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>

	<Footer />
	
	<a href="https://wa.me/254769696309?text=Hi%20Albachuza!%20I'd%20like%20to%20make%20an%20%20inquiry!" target="_blank" rel="noopener noreferrer" aria-label="Chat with us on WhatsApp" class="whatsapp_customer_service_btn">
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-6 h-6">
			<path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7 .9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
		</svg>
    </a>
            
</Layout>
